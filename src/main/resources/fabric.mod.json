	"entrypoints": {
		"main": [
			"com.adriansimo.sayas.SayAsMod"
		],
		"client": [
			"com.adriansimo.sayas.SayAsClient"
		]
	},
	"mixins": [
		"sayas.mixins.json",
		{
			"config": "sayas.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.1",
